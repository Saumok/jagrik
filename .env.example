# ============================================================================
# Jagrik environment. Copy to `.env` and fill in to go from demo to fully live.
# The app RUNS without any of these (graceful demo fallback); each key you add
# turns one capability real. Never commit your real .env.
# ============================================================================

# --- Server (secret; lives on Cloud Run in prod) ---

# Gemini API key from the BILLING-DISABLED project `jagrik-ai` (Docs/07 §1).
# Without it, classification/drafting use a deterministic fallback.
GEMINI_API_KEY=

# ⚠️ VERIFY the exact free-tier multimodal Flash model id in Google AI Studio.
GEMINI_MODEL=gemini-2.5-flash

# Real email dispatch via Gmail app-password (Docs/07 §5). Create an app
# password at https://myaccount.google.com/apppasswords (needs 2FA on).
# Without these, the email step is simulated (clearly marked in the war-room).
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM=

# The controlled demo inbox ALL complaints route to during testing — never real
# municipal staff (Docs/00, Docs/07 §5). If set, overrides the per-department address.
DEMO_INBOX=

# Real email that works on hosts blocking SMTP (e.g. Render). Sign up at
# resend.com (free, no card) → create an API key. In test mode, `to` must be
# your own Resend signup email (set DEMO_INBOX to it). Preferred over Gmail when set.
RESEND_API_KEY=
RESEND_FROM=Jagrik <onboarding@resend.dev>

# Durable storage (Firestore). Base64 of your Firebase service-account JSON:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))
# Without it, the app uses in-memory storage (resets on restart).
FIREBASE_SERVICE_ACCOUNT_B64=

# Backend port (Vite dev proxies /api here).
PORT=8787

# --- Client (public, VITE_-prefixed) — for later phases (Maps/Firebase) ---
# VITE_MAPS_API_KEY=
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_STORAGE_BUCKET=
